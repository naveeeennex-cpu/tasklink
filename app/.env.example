# LOKAL Flutter app — copy to `.env` and fill in values.
#
# 10.0.2.2 is the Android emulator's loopback to host machine. For iOS
# simulator use localhost; for physical device use your LAN IP.
BACKEND_URL=http://10.0.2.2:8000

# Supabase — Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
