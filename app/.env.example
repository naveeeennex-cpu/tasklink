# LOKAL Flutter app — copy to `.env` and fill in values.
#
# BACKEND_URL — the Railway-deployed FastAPI backend (production).
# For local-only development, set this to:
#   - http://10.0.2.2:8000   (Android emulator)
#   - http://localhost:8000  (iOS simulator)
#   - http://<your-lan-ip>:8000  (physical device on the same wifi)
BACKEND_URL=https://tasklink-production-7846.up.railway.app

# Supabase — Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
